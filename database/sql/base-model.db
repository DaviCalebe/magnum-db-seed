-- =========================
-- ENUMS (padronização)
-- =========================

CREATE TYPE status_geral AS ENUM ('ativo', 'inativo');
CREATE TYPE tipo_movimentacao AS ENUM ('entrada', 'saida', 'ajuste');

-- =========================
-- TABELAS PRINCIPAIS
-- =========================

CREATE TABLE unidades (
  id SERIAL PRIMARY KEY,
  nome VARCHAR(150) NOT NULL,
  cnpj VARCHAR(18) UNIQUE,
  telefone VARCHAR(20),
  email VARCHAR(100),
  endereco VARCHAR(150),
  cidade VARCHAR(100),
  estado VARCHAR(50),
  cep VARCHAR(10),

  status status_geral DEFAULT 'ativo',

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE setores (
  id SERIAL PRIMARY KEY,
  nome VARCHAR(100) NOT NULL,
  descricao TEXT,

  status status_geral DEFAULT 'ativo',

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE produtos (
  id SERIAL PRIMARY KEY,
  nome VARCHAR(150) NOT NULL,
  descricao TEXT,

  preco DECIMAL(10,2) NOT NULL,

  status status_geral DEFAULT 'ativo',

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE clientes (
  id SERIAL PRIMARY KEY,
  nome VARCHAR(150) NOT NULL,
  email VARCHAR(150),
  telefone VARCHAR(20),

  status status_geral DEFAULT 'ativo',

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================
-- COLABORADORES
-- =========================

CREATE TABLE colaboradores (
  id SERIAL PRIMARY KEY,
  nome VARCHAR(150) NOT NULL,
  email VARCHAR(150),
  telefone VARCHAR(20),

  ocupacao VARCHAR(100),

  unidade_id INT NOT NULL REFERENCES unidades(id)
    ON UPDATE CASCADE
    ON DELETE RESTRICT,

  setor_id INT REFERENCES setores(id)
    ON UPDATE CASCADE
    ON DELETE SET NULL,

  status status_geral DEFAULT 'ativo',

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================
-- ESTOQUE
-- =========================

CREATE TABLE estoque (
  id SERIAL PRIMARY KEY,

  produto_id INT NOT NULL REFERENCES produtos(id)
    ON UPDATE CASCADE
    ON DELETE RESTRICT,

  unidade_id INT NOT NULL REFERENCES unidades(id)
    ON UPDATE CASCADE
    ON DELETE RESTRICT,

  quantidade INT NOT NULL DEFAULT 0,

  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  UNIQUE (produto_id, unidade_id)
);

-- =========================
-- MOVIMENTAÇÕES
-- =========================

CREATE TABLE movimentacoes (
  id SERIAL PRIMARY KEY,

  tipo tipo_movimentacao NOT NULL,

  produto_id INT REFERENCES produtos(id)
    ON UPDATE CASCADE
    ON DELETE SET NULL,

  quantidade INT NOT NULL,

  valor_unitario DECIMAL(10,2),

  valor_total DECIMAL(10,2) NOT NULL,

  data TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  cliente_id INT REFERENCES clientes(id)
    ON UPDATE CASCADE
    ON DELETE SET NULL,

  colaborador_id INT NOT NULL REFERENCES colaboradores(id)
    ON UPDATE CASCADE
    ON DELETE RESTRICT,

  unidade_id INT NOT NULL REFERENCES unidades(id)
    ON UPDATE CASCADE
    ON DELETE RESTRICT,

  observacao TEXT,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);